# Vecxel API - Configuración de entorno

# Puerto del servidor FastAPI
PORT=8000

# MongoDB para Vecxel App (NO para SAC)
MONGODB_URI=mongodb://localhost:27019/vecxel_app

# API Key para autenticación de este servicio
API_KEY=clave_de_prueba

# SAC Connector - Conexión HTTP
SAC_CONNECTOR_URL=http://localhost:4000
SAC_CONNECTOR_API_KEY=clave_de_prueba
